#!/usr/bin/env bash

set -euo pipefail

CONTAINER_NAME="${FERROCOPG_TEST_DB_CONTAINER:-postgres}"
PORT="${FERROCOPG_TEST_DB_PORT:-5432}"
USER_NAME="${FERROCOPG_TEST_DB_USER:-postgres}"
PASSWORD="${FERROCOPG_TEST_DB_PASSWORD:-password}"
DB_NAME="${FERROCOPG_TEST_DB_NAME:-postgres}"
HOST_NAME="${FERROCOPG_TEST_DB_HOST:-127.0.0.1}"

default_image() {
  printf '%s\n' "postgres:17"
}

IMAGE_NAME="${FERROCOPG_TEST_DB_IMAGE:-$(default_image)}"

dsn() {
  printf 'postgresql://%s:%s@%s:%s/%s\n' \
    "$USER_NAME" "$PASSWORD" "$HOST_NAME" "$PORT" "$DB_NAME"
}

container_exists() {
  docker ps -a --format '{{.Names}}' | grep -Fxq "$CONTAINER_NAME"
}

remove_container() {
  if container_exists; then
    docker rm -f "$CONTAINER_NAME" >/dev/null
  fi
}

wait_for_db() {
  local attempt
  for attempt in $(seq 1 60); do
    if docker exec "$CONTAINER_NAME" pg_isready -U "$USER_NAME" -d "$DB_NAME" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done

  echo "database did not become ready in time" >&2
  docker logs "$CONTAINER_NAME" >&2 || true
  return 1
}

cmd_start() {
  remove_container
  docker pull "$IMAGE_NAME"
  docker run --rm -d --name "$CONTAINER_NAME" -p "$PORT:5432" \
    -e "POSTGRES_USER=$USER_NAME" \
    -e "POSTGRES_PASSWORD=$PASSWORD" \
    -e "POSTGRES_DB=$DB_NAME" \
    "$IMAGE_NAME" \
    -c max_prepared_transactions=10 >/dev/null
  wait_for_db
  echo "test database is ready"
  echo "PSYCOPG_TEST_DSN=$(dsn)"
}

cmd_stop() {
  remove_container
}

cmd_reset() {
  remove_container
}

cmd_status() {
  docker ps -a --filter "name=$CONTAINER_NAME"
}

cmd_logs() {
  docker logs -f "$CONTAINER_NAME"
}

cmd_dsn() {
  dsn
}

usage() {
  cat <<EOF
Usage: tools/test-db <command>

Commands:
  start   Start the PostgreSQL test database and wait until it is ready
  stop    Stop the PostgreSQL test database
  reset   Stop the database and remove its volume
  status  Show docker compose status
  logs    Follow PostgreSQL logs
  dsn     Print the PSYCOPG_TEST_DSN value

Environment overrides:
  FERROCOPG_TEST_DB_HOST
  FERROCOPG_TEST_DB_PORT
  FERROCOPG_TEST_DB_USER
  FERROCOPG_TEST_DB_PASSWORD
  FERROCOPG_TEST_DB_NAME
  FERROCOPG_TEST_DB_IMAGE
  FERROCOPG_TEST_DB_CONTAINER
EOF
}

main() {
  local command="${1:-}"
  case "$command" in
    start) cmd_start ;;
    stop) cmd_stop ;;
    reset) cmd_reset ;;
    status) cmd_status ;;
    logs) cmd_logs ;;
    dsn) cmd_dsn ;;
    *)
      usage
      if [[ -n "$command" ]]; then
        exit 1
      fi
      ;;
  esac
}

main "$@"
